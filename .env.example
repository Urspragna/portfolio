# Copy to .env and fill in the values you want to use.
# Every variable is OPTIONAL — sensible defaults make the app run without any.

# ─── App ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME="Pragna AI Portfolio"

# ─── Database ────────────────────────────────────────────────────────
# Default: local SQLite file. No setup needed.
# DATABASE_URL=sqlite+aiosqlite:///./portfolio.db
#
# Production (uncomment after running `docker compose up db`):
# DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@localhost:5432/portfolio

# ─── LLM provider ────────────────────────────────────────────────────
# Options: anthropic | ollama | echo (default)
LLM_PROVIDER=echo

# Required only if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required only if LLM_PROVIDER=ollama (and you have `ollama serve` running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Embeddings ──────────────────────────────────────────────────────
# Options: sbert (default — downloads a small model on first run) | hash (deterministic offline fallback)
EMBEDDING_PROVIDER=sbert
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
